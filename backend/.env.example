# ─── RailTrack AI — Backend Environment Variables ─────────────────────────────
# Copy this file to .env and fill in all values before running.
# NEVER commit the actual .env file (it is in .gitignore).

# ──────────────────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────────────────
# Local dev:
#   DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/railtrack
# Production (Railway):
#   DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/<db>
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/railtrack

# ──────────────────────────────────────────────────────────────────────────────
# Authentication — JWT
# ──────────────────────────────────────────────────────────────────────────────
# Generate a secure key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ──────────────────────────────────────────────────────────────────────────────
# Gmail SMTP — Email invite system
# ──────────────────────────────────────────────────────────────────────────────
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# ──────────────────────────────────────────────────────────────────────────────
# CORS — Allowed frontend origins (comma-separated)
# ──────────────────────────────────────────────────────────────────────────────
# Local dev:
#   ALLOWED_ORIGINS=http://localhost:3000
# Production:
#   ALLOWED_ORIGINS=https://railtrack.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# Frontend URL — used in invite email links
# ──────────────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# RapidAPI — IRCTC Live Train Tracker
# ──────────────────────────────────────────────────────────────────────────────
RAPIDAPI_KEY=your-rapidapi-key-here
RAPIDAPI_HOST=indian-railway-irctc.p.rapidapi.com

# ──────────────────────────────────────────────────────────────────────────────
# Groq AI — Chat API
# ──────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key-here

# ──────────────────────────────────────────────────────────────────────────────
# Google OAuth (optional)
# ──────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id
